# Production image for the Hocuspocus collab server (servers/y-provider).
FROM node:22-bookworm-slim
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund --omit=dev
COPY servers ./servers
ENV COLLAB_PORT=1234
EXPOSE 1234
# Set COLLAB_BACKEND_URL to enable cookie -> Django abilities auth.
CMD ["node", "servers/y-provider/server.mjs"]
