# Environment for the `full` docker compose profile (Keycloak SSO).
#
#   cp .env.example .env
#   docker compose --profile full --env-file .env up
#
# These are DEVELOPMENT placeholders. Never reuse them in a real deployment: generate strong,
# unique secrets and serve everything over TLS. Add `127.0.0.1 keycloak` to /etc/hosts so the
# OIDC issuer resolves the same for the browser and the backend.

# Installs the backend `oidc` extra (django-lasuite) so OIDC login is available.
OIDC_EXTRA=,oidc

# OIDC provider endpoints (realm `slides` from config/keycloak/realm.json).
OIDC_OP_JWKS_ENDPOINT=http://keycloak:8080/realms/slides/protocol/openid-connect/certs
OIDC_OP_AUTHORIZATION_ENDPOINT=http://keycloak:8080/realms/slides/protocol/openid-connect/auth
OIDC_OP_TOKEN_ENDPOINT=http://keycloak:8080/realms/slides/protocol/openid-connect/token
OIDC_OP_USER_ENDPOINT=http://keycloak:8080/realms/slides/protocol/openid-connect/userinfo
OIDC_OP_LOGOUT_ENDPOINT=http://keycloak:8080/realms/slides/protocol/openid-connect/logout

# Relying-party (must match config/keycloak/realm.json).
OIDC_RP_CLIENT_ID=slides-backend
OIDC_RP_CLIENT_SECRET=dev-slides-backend-secret-change-me
OIDC_RP_SCOPES=openid email profile
OIDC_REDIRECT_ALLOWED_HOSTS=localhost:8000,localhost:3000
LOGIN_REDIRECT_URL=http://localhost:3000/
LOGOUT_REDIRECT_URL=http://localhost:3000/

# Browser origins allowed on the API (CORS) and on the collab websocket. Wildcards are not
# supported: list each origin explicitly. In production, set these to the public app origin.
CORS_ALLOWED_ORIGINS=http://localhost:3000
COLLAB_WS_ALLOWED_ORIGINS=http://localhost:3000

# Production refuses to start without OIDC configured. Set to true only for a deliberately
# anonymous demo deployment (every visitor shares world-editable decks).
# DJANGO_ALLOW_ANONYMOUS_API=false
